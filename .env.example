# ============================================================
# Arterial Impact Report — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your keys:
#   cp .env.example .env.local
# ============================================================

# --- RAG / Vector Database ---
# Pinecone: Vector database for the knowledge base
# Sign up (free tier): https://www.pinecone.io
PINECONE_API_KEY=

# --- AI Models ---
# Google Gemini: Embeddings (Gemini Embedding 2) and File Search
# Get key: https://aistudio.google.com → Get API Key
GOOGLE_AI_API_KEY=

# Anthropic: Claude API for report content generation
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Open Router (optional): Multi-model access for chat interface
# Get key: https://openrouter.ai → Account → API Keys
OPENROUTER_API_KEY=

# --- Content Scraping ---
# FireCrawl: Web scraping and URL crawling
# Sign up: https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Images ---
# Unsplash: Stock image search for placeholders
# Get key: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# --- Data / CMS ---
# Airtable: URL management and scrape tracking
# Get key: https://airtable.com/account → API
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- Deployment ---
# Vercel: Auto-deploys from GitHub (configured via Vercel dashboard)
# No key needed here — Vercel reads env vars from its own settings
