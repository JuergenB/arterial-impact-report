# ============================================================
# Arterial Impact Report — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your keys:
#   cp .env.example .env.local
#
# See GETTING-STARTED.md for step-by-step signup instructions
# for each service listed below.
# ============================================================

# --- AI Models (for automations, agents, and pipelines) ---
# NOTE: These are SEPARATE from the Claude Code subscription ($100/mo).
# Claude Code covers interactive dev sessions. These API keys cover
# AI models used in background automations, LLM agents, classification,
# scoring, and other programmatic tasks.

# Anthropic: Claude models for content generation, analysis, agents
# Sign up: https://console.anthropic.com → API Keys → Create Key
# Set a monthly spend limit under Settings → Billing
ANTHROPIC_API_KEY=

# OpenAI: GPT-4o, GPT-4.1 for classification, scoring, automation tasks
# Sign up: https://platform.openai.com → API Keys → Create new secret key
# Set a monthly spend limit under Settings → Limits
OPENAI_API_KEY=

# Google Gemini: Embeddings (Gemini Embedding 2) and File Search
# Sign up: https://aistudio.google.com → Get API Key
GOOGLE_AI_API_KEY=

# --- Image Generation ---

# Replicate: AI image generation (Flux, SDXL, Ideogram, etc.)
# Sign up: https://replicate.com → Account → API Tokens
REPLICATE_API_TOKEN=

# --- RAG / Vector Database ---

# Pinecone: Vector database for the knowledge base
# Sign up (free tier): https://app.pinecone.io → API Keys
PINECONE_API_KEY=

# --- Content Scraping ---

# FireCrawl: Web scraping and URL crawling
# Sign up: https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Stock Images ---

# Unsplash: Stock image search for placeholders
# Sign up: https://unsplash.com/developers → Register as developer
UNSPLASH_ACCESS_KEY=

# --- Project Data & Config ---

# Airtable: Structured config (crawl targets, section config, content sources, verification queue)
# Sign up: https://airtable.com → Account → Developer Hub → Personal Access Tokens
# Base ID: Open your base → Help → API Documentation → base ID starts with "app"
# Table IDs: Found in the URL when viewing a table, or via Airtable API metadata endpoint
AIRTABLE_PERSONAL_ACCESS_TOKEN=
AIRTABLE_BASE_ID=
# Table-specific IDs (populate after base is created)
AIRTABLE_CRAWL_TARGETS_TABLE_ID=
AIRTABLE_CONTENT_SOURCES_TABLE_ID=
AIRTABLE_SECTION_CONFIG_TABLE_ID=
AIRTABLE_VERIFICATION_QUEUE_TABLE_ID=

# --- Workflow Automation ---

# n8n: Workflow automation (Dropbox watch, AI pipelines, scrape scheduling)
# Cloud instance URL and API key
N8N_API_KEY=
N8N_INSTANCE_URL=

# --- Deployment ---
# Vercel: Auto-deploys from GitHub (configured via Vercel dashboard)
# No key needed here — Vercel reads env vars from its own settings
